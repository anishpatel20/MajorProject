<% layout("/layouts/boilerplate.ejs") %>



    <!-- <h1>All listings</h1>  -->

    <style>
        .filter-catogery {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }


        .filters {
            display: flex;
            align-items: center;
            overflow-x: auto;
            /*If content becomes wider than the container → enable horizontal scrolling.*/
            white-space: nowrap;
            /*But nowrap forces everything to stay in one line.*/
            flex: 1;
            /*Take all remaining space in the container.*/
        }


        /* hide scrollbar */
        .filters::-webkit-scrollbar {
            display: none;
        }

        .filter {
            text-align: center;
            margin-right: 2rem;
            margin-top: 1rem;
            opacity: 0.7;
            text-decoration: none;
        }

        .filter:hover {
            opacity: 1;
            cursor: pointer;
        }

        .filter p {
            font-size: 0.9rem;
        }


        .tax-info {
            display: none;
        }

        .tax-toggle {
            border: 1px solid black;
            border-radius: 1rem;
            height: 3.25rem;
            padding: 1rem;
            margin-left: 2rem;
            display: flex;
            align-items: center;

        }
        a{
            text-decoration: none;
            color: black;
        }
    </style>



    <div class="filter-catogery">
        <div class="filters">

            <a href="/listings/category/trending">
                <div class="filter">
                    <div><i class="fa-solid fa-fire"></i></div>
                    <p> Treding</p>
                </div>
            </a>

            <a href="/listings/category/room">
                <div class="filter">
                    <div><i class="fa-solid fa-bed"></i></div>
                    <p> Room</p>
                </div>
            </a>

            <a href="/listings/category/iconic_cities">
                <div class="filter">
                    <div><i class="fa-solid fa-mountain-city"></i></div>
                    <p> Iconic cities</p>
                </div>
            </a>

            <a href="/listings/category/mountain">
                <div class="filter">
                    <div><i class="fa-solid fa-mountain"></i></div>
                    <p>Mountain</p>
                </div>
            </a>

            <a href="/listings/category/castle">
                <div class="filter">
                    <div><i class="fa-brands fa-fort-awesome"></i></div>
                    <p>castle</p>
                </div>
            </a>

            <a href="/listings/category/Amazing_pool">
                <div class="filter">
                    <div><i class="fa-solid fa-person-swimming"></i></div>
                    <p>Amazing pool</p>
                </div>
            </a>


            <a href="/listings/category/camping">
                <div class="filter">
                    <div><i class="fa-solid fa-campground"></i></div>
                    <p>camping</p>
                </div>
            </a>

            <a href="/listings/category/farm">
                <div class="filter">
                    <div><i class="fa-solid fa-cow"></i></div>
                    <p>Farms</p>
                </div>
            </a>

            <a href="/listings/category/beach">
                <div class="filter">
                    <div><i class="fa-solid fa-umbrella-beach"></i></div>
                    <p>Beach</p>
                </div>


                <a href="/listings/category/arctic">
                    <div class="filter">
                        <div><i class="fa-regular fa-snowflake"></i></div>
                        <p>Arctic</p>
                    </div>
                </a>

                <a href="/listings/category/tree_house">
                    <div class="filter">
                        <div><i class="fa-solid fa-tree"></i></div>
                        <p>tree house</p>
                    </div>
                </a>

                <a href="/listings/category/house_boat">
                    <div class="filter">
                        <div><i class="fa-solid fa-sailboat"></i></div>
                        <p>house boat</p>
                    </div>
                </a>

                <a href="/listings/category/others">
                    <div class="filter">
                        <div><i class="fa-solid fa-globe"></i></div>
                        <p>Others</p>
                    </div>
                </a>

        </div>

        <!-- switch  -->
        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>

    </div>


    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1  mt-3">
        <!-- add the card in the rows by using the bootstrap-->

        <%for(let listing of allListings){ %>
            <a href="/listings/<%= listing._id %>" class="listing-link">
                <!-- when click on imgage then oepn it seprately -->
                <div class="card col listing-card">
                    <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_img" style="height:20rem;">

                    <div class="card-img-overlay"></div> <!-- overlay div  -->

                    <div class="card-body">
                        <p class="card-text">
                            <b>
                                <%= listing.title %>
                            </b>
                            <br>
                            &#8377;<%= listing.price.toLocaleString("en-IN") %>/night
                                <i class="tax-info"> &nbsp;&nbsp; +18% GST</i>
                        </p>
                    </div>
                </div>
            </a>
        <% } %>
        
        

            <% if(allListings.length == 0) {%>
                <h4 class="zero-listing"> <i class="fa-solid fa-eye-slash"></i> No listing is Found</h4>
            <% } %>

    </div>

    <script>
        let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("click", () => {
            let taxInfo = document.getElementsByClassName("tax-info");
            for (info of taxInfo) {
                if (info.style.display != "inline") {
                    info.style.display = "inline";
                }
                else {
                    info.style.display = "none";
                }
            }

        })
    </script>